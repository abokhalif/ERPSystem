@{
    ViewData["Title"] = "Dashboard";
}
<style>
    .card {
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .card:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

</style>
<main role="main" class="pb-3">
    <div class="dashboard-cards">
        <div class="card">
            <h3>Total Employees</h3>
            <p>150</p>
        </div>
        <div class="card">
            <h3>New Hires</h3>
            <p>10</p>
        </div>
        <div class="card">
            <h3>Departments</h3>
            <p>5</p>
        </div>
    </div>
</main>
