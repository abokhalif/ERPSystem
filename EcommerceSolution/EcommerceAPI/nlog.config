<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="internal-nlog.txt">

	<!-- ================== Targets ================== -->
	<targets>
		<!-- File logging -->
		<target xsi:type="File"
				name="fileLogger"
				fileName="${basedir}/logs/${shortdate}.log"
				layout="${longdate} | ${uppercase:${level}} | ${logger} | ${message} ${exception:format=toString,Data:maxInnerExceptionLevel=10}" />

		<!-- Console logging -->
		<target xsi:type="Console"
				name="consoleLogger"
				layout="${longdate} | ${uppercase:${level}} | ${logger} | ${message} ${exception}" />
	</targets>

	<!-- ================== Rules ================== -->
	<rules>
		<!-- Log Info, Warn, Error to both Console and File -->
		<logger name="*" minlevel="Info" writeTo="consoleLogger,fileLogger" />
	</rules>
</nlog>
