@model IEnumerable<Employee>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>
<a asp-action="Create" class="btn btn-primary">CreateNew</a>

<div>
    <h4>Employee</h4>
    <hr />
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.EmployeeNumber)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.EmployeeName)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.DOB)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.HiringDate)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.GrossSalary)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.NetSalary)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.DepartmentName)
                </th>
              
                <th>Edit</th>
                <th>Delete</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.EmployeeNumber)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.EmployeeName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.DOB)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.HiringDate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.GrossSalary)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.NetSalary)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.DepartmentName)
                    </td>
                    
                    <td>
                        <a asp-action="Edit" asp-route-id="item?.EmployeetId">Edit</a>
                    </td>
                    <td>
                        <a asp-action="Delete" asp-route-id="item?.EmployeetId">Delete</a>
                    </td>

                </tr>
            }

        </tbody>
    </table>
        
</div>
<div>
    <a asp-action="Index">Back to List</a>

</div>
