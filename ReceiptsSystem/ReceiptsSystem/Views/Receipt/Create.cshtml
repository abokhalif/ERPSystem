@{
}
@model ReceiptsSystem.ViewModels.ReceiptViewModel

<h1>Create New Receipt</h1>

@using (Html.BeginForm("AddItem", "Receipt", FormMethod.Post))
{
    <div class="form-group">
        <label for="ItemId">Item:</label>
        <select class="form-control" id="ItemId" name="ReceiptItem.ItemID">
            @foreach (var item in Model.Items)
            {
                <option value="@item.ItemID">@item.Name</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label for="Quantity">Quantity:</label>
        <input type="number" class="form-control" id="Quantity" name="ReceiptItem.Quantity" required>
    </div>
    <button type="submit" class="btn btn-primary">Add Item</button>
}

<h2>Receipt Items</h2>
<ul>
    @foreach (var receiptItem in Model.Receipt.ReceiptItems)
    {
        <li>@receiptItem.Item.Name - @receiptItem.Quantity</li>
    }
</ul>

<h3>Total Amount: @Model.Receipt.TotalAmount</h3>

@using (Html.BeginForm("EnterPaidAmount", "Receipt", FormMethod.Post))
{
    <div class="form-group">
        <label for="PaidAmount">Paid Amount:</label>
        <input type="number" class="form-control" id="PaidAmount" name="Receipt.PaidAmount" required>
    </div>
    <button type="submit" class="btn btn-primary">Enter Paid Amount</button>
}

<h3>Remaining Amount: @Model.Receipt.RemainingAmount</h3>

@using (Html.BeginForm("CreateReceipt", "Receipt", FormMethod.Post))
{
    <button type="submit" class="btn btn-success">Create Receipt</button>
}
