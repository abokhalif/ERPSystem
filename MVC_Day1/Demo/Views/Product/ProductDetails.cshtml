<div class="card" style="width:400px">
    <img class="card-img-top" src="/Images/@Model.Image" style="width:50%">
    <div class="card-body">
        <h4 class="card-title">@Model.Name</h4>
        <p class="card-text">@Model.Price - @Model.Description</p>
        <a href="#" class="btn btn-primary">See Profile</a>
    </div>
</div>
